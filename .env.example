# Rose Glass News — Environment Variables
# Copy this to .env.local and fill in values
# DO NOT commit .env.local

# Supabase connection string (from Supabase dashboard → Settings → Database → Connection string → URI)
# Use the "Transaction" pooler URL for serverless (port 6543), not direct (5432)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: only needed for cron/ingest scripts (not Vercel)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json
